<view class="page-shell home-page">
  <view class="panel home-hero">
    <view class="hero-top">
      <view class="hero-copy">
        <view class="hero-title">热成像监测</view>
        <view class="hero-device">{{dashboard.displayName}}</view>
        <view class="hero-subtitle">{{dashboard.modelText}}</view>
      </view>
      <view class="status-pill {{dashboard.online.tone}}">{{dashboard.online.text}}</view>
    </view>
    <view class="hero-meta">最近上报 {{dashboard.latestUpdateText}}</view>
    <view class="hero-note">{{dashboard.latestUpdateRelativeText}} · 云端同步 {{dashboard.fetchedAtText}}</view>
  </view>

  <view class="metrics-grid">
    <view
      wx:for="{{metrics}}"
      wx:key="key"
      class="metric-card metric-{{item.tone}} {{item.featured ? 'featured' : ''}}"
    >
      <view class="metric-label">{{item.label}}</view>
      <view class="metric-value">{{item.valueText}}</view>
      <view class="metric-unit">{{item.unitLabel}}</view>
    </view>
  </view>

  <view class="panel status-panel {{dashboard.thermalStatus.tone}}">
    <view class="status-header">
      <view>
        <view class="section-title">当前状态</view>
        <view class="section-subtitle">按最高温和本地报警阈值实时判断</view>
      </view>
      <view class="status-pill {{dashboard.thermalStatus.tone}}">{{dashboard.thermalStatus.label}}</view>
    </view>
    <view class="status-title">{{dashboard.thermalStatus.label}}</view>
    <view class="status-description">{{dashboard.thermalStatus.description}}</view>
    <view class="status-threshold">报警阈值：{{dashboard.thresholdText}}</view>
  </view>

  <view class="error-card" wx:if="{{errorMessage}}">
    <view class="error-title">刷新失败</view>
    <view class="error-text">{{errorMessage}}</view>
  </view>

  <view class="action-grid">
    <button class="primary-button" bindtap="onRefreshTap" loading="{{loading}}">
      {{loading ? "正在刷新..." : "立即刷新"}}
    </button>
    <button class="secondary-button" bindtap="goHistory">查看历史</button>
    <button class="secondary-button" bindtap="goSettings">设备设置</button>
  </view>

  <view class="empty-card" wx:if="{{!errorMessage && dashboard.latestUpdateText === '--'}}">
    <view class="empty-title">等待第一条热成像数据</view>
    <view class="empty-text">设备上线并上报后，首页会自动显示最高温、中心温和最低温。</view>
  </view>
</view>
