.home-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.home-hero {
  background:
    radial-gradient(circle at top left, rgba(255, 208, 166, 0.32), transparent 36%),
    linear-gradient(135deg, rgba(255, 146, 72, 0.96), rgba(151, 62, 30, 0.94)),
    #ff8d4a;
  color: #fff8ef;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: flex-start;
}

.hero-copy {
  flex: 1;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.08;
}

.hero-device {
  margin-top: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.65;
  color: rgba(255, 248, 240, 0.84);
}

.hero-facts {
  margin-top: 26rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.hero-fact {
  padding: 18rpx 18rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 248, 240, 0.12);
  backdrop-filter: blur(10rpx);
}

.hero-fact-label {
  font-size: 21rpx;
  color: rgba(255, 248, 240, 0.7);
}

.hero-fact-value {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff8ef;
}

.snapshot-banner {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 240, 0.14);
}

.snapshot-banner.normal {
  background: rgba(255, 248, 240, 0.16);
}

.snapshot-banner.offline,
.snapshot-banner.pending {
  background: rgba(58, 33, 20, 0.18);
}

.snapshot-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff8ef;
}

.snapshot-text {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: rgba(255, 248, 240, 0.84);
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.metric-card {
  position: relative;
  overflow: hidden;
  padding: 24rpx 22rpx;
  border-radius: 26rpx;
  background: rgba(255, 252, 246, 0.95);
  box-shadow: 0 18rpx 36rpx rgba(53, 36, 22, 0.08);
}

.metric-card::before {
  content: "";
  position: absolute;
  right: -24rpx;
  bottom: -34rpx;
  width: 132rpx;
  height: 132rpx;
  border-radius: 50%;
  opacity: 0.16;
}

.metric-card.featured {
  grid-column: 1 / span 2;
  padding-top: 28rpx;
  padding-bottom: 30rpx;
}

.metric-card.stale {
  background: rgba(247, 243, 236, 0.94);
}

.metric-max::before {
  background: #f16d34;
}

.metric-center::before {
  background: #f0b443;
}

.metric-min::before {
  background: #5f8dff;
}

.metric-head {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  align-items: center;
}

.metric-label {
  font-size: 24rpx;
  color: #7b6758;
}

.metric-state {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(36, 27, 21, 0.06);
  font-size: 20rpx;
  color: #7a6c61;
}

.metric-value {
  margin-top: 18rpx;
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1;
  color: #231711;
}

.metric-card:not(.featured) .metric-value {
  font-size: 50rpx;
}

.metric-unit {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8e796b;
}

.status-header {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: flex-start;
}

.status-title {
  margin-top: 22rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #241b15;
}

.status-description {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #6f6258;
}

.status-threshold {
  margin-top: 18rpx;
  font-size: 23rpx;
  color: #8e796b;
}

.home-refresh-button {
  width: 100%;
}
