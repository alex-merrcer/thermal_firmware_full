<view class="page-shell device-page">
  <view class="panel device-hero">
    <view class="device-hero-top">
      <view>
        <view class="section-title">设备管理</view>
        <view class="device-name">{{device.displayName}}</view>
        <view class="section-subtitle">{{device.snapshotStateText}}</view>
      </view>
      <view class="status-pill {{device.online.tone}}">{{device.online.text}}</view>
    </view>
    <view class="device-meta">最后上报：{{device.latestUpdateText}}</view>
    <view class="device-note">云端检查：{{device.fetchedAtText}}</view>
  </view>

  <view class="panel">
    <view class="section-title">设备概览</view>
    <view class="section-subtitle">{{device.snapshotDescription}}</view>

    <view class="info-row">
      <view class="info-key">设备名称</view>
      <view class="info-value">{{device.displayName}}</view>
    </view>
    <view class="info-row">
      <view class="info-key">设备状态</view>
      <view class="info-value">{{device.online.text}}</view>
    </view>
    <view class="info-row">
      <view class="info-key">最后上报</view>
      <view class="info-value">{{device.latestUpdateText}}</view>
    </view>
    <view class="info-row">
      <view class="info-key">更新说明</view>
      <view class="info-value">{{device.latestUpdateRelativeText}}</view>
    </view>
    <view class="info-row">
      <view class="info-key">设备类型</view>
      <view class="info-value">红外热成像测温终端</view>
    </view>
  </view>

  <button class="primary-button" bindtap="onRefreshTap" loading="{{loading}}">
    {{loading ? "正在刷新..." : "刷新设备信息"}}
  </button>

  <view class="error-card" wx:if="{{errorMessage}}">
    <view class="error-title">设备信息加载失败</view>
    <view class="error-text">{{errorMessage}}</view>
  </view>
</view>
