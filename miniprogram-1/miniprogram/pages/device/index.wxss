.device-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.device-hero {
  background:
    linear-gradient(145deg, rgba(255, 250, 241, 0.98), rgba(246, 238, 226, 0.94)),
    #fffaf1;
}

.device-hero-top {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: flex-start;
}

.device-name {
  margin-top: 18rpx;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #241b15;
}

.device-meta {
  margin-top: 22rpx;
  font-size: 24rpx;
  color: #4e3c31;
}

.device-note {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #8b7d70;
}

.entry-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid rgba(36, 27, 21, 0.08);
}

.entry-row:first-of-type {
  margin-top: 12rpx;
}

.entry-copy {
  flex: 1;
}

.entry-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #241b15;
}

.entry-desc {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #7e7165;
}

.entry-action {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #8a3f23;
}
