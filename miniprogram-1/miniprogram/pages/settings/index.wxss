.settings-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.setting-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: center;
  padding: 22rpx 0;
  border-top: 1rpx solid rgba(36, 27, 21, 0.08);
}

.setting-row:first-of-type {
  margin-top: 12rpx;
}

.setting-copy {
  flex: 1;
}

.setting-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #241b15;
}

.setting-desc {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #7d6f62;
}

.setting-value {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #5c4434;
}

.ble-entry {
  cursor: pointer;
}

.input-label {
  margin-top: 22rpx;
  font-size: 24rpx;
  color: #7c7066;
}

.setting-input {
  margin-top: 12rpx;
  height: 80rpx;
  border-radius: 22rpx;
  background: rgba(247, 243, 236, 0.92);
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #241b15;
}

.button-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.button-row .primary-button,
.button-row .secondary-button {
  width: auto;
  flex: 1 1 0;
  min-width: 0;
  min-height: 58rpx;
  padding: 0 10rpx;
  border-radius: 22rpx;
  font-size: 22rpx;
  line-height: 1.2;
}

.single-action {
  margin-top: 18rpx;
}

.device-summary {
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: center;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(248, 243, 236, 0.92);
}

.device-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #241b15;
}

.device-status {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #8b7d70;
}

.version-card {
  text-align: center;
}

.version-hint {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7b6b5e;
}
