<view class="page-shell settings-page">
  <view class="panel">
    <view class="section-title">基础设置</view>
    <view class="section-subtitle">温度单位、自动刷新和刷新频率都会保存在本地设置中。</view>

    <picker range="{{unitOptions}}" value="{{unitIndex}}" bindchange="onUnitChange">
      <view class="setting-row">
        <view class="setting-copy">
          <view class="setting-title">温度单位</view>
          <view class="setting-desc">首页和历史页会按当前单位显示温度。</view>
        </view>
        <view class="setting-value">{{currentUnitLabel}}</view>
      </view>
    </picker>

    <view class="setting-row">
      <view class="setting-copy">
        <view class="setting-title">自动刷新</view>
        <view class="setting-desc">回到首页后，会按设定频率自动拉取最新快照。</view>
      </view>
      <switch checked="{{autoRefreshEnabled}}" color="#A24B2A" bindchange="onAutoRefreshChange" />
    </view>

    <picker range="{{intervalOptions}}" value="{{intervalIndex}}" bindchange="onIntervalChange">
      <view class="setting-row">
        <view class="setting-copy">
          <view class="setting-title">刷新间隔</view>
          <view class="setting-desc">当前支持 5 / 10 / 15 / 30 / 60 秒。</view>
        </view>
        <view class="setting-value">{{currentIntervalLabel}}</view>
      </view>
    </picker>
  </view>

  <view class="panel">
    <view class="section-title">网络连接</view>
    <view class="section-subtitle">更换路由器或密码后，可以在这里重新联网。</view>

    <view class="setting-row ble-entry" bindtap="onBleProvisionTap">
      <view class="setting-copy">
        <view class="setting-title">重新联网</view>
        <view class="setting-desc">搜索附近设备，重新输入 Wi‑Fi 信息，并查看连接进度。</view>
      </view>
      <view class="setting-value">进入</view>
    </view>
  </view>

  <view class="panel">
    <view class="section-title">报警阈值</view>
    <view class="section-subtitle">首页会用最高温和这个阈值判断“正常 / 偏高 / 报警”。</view>

    <view class="input-label">报警阈值（°C）</view>
    <input
      class="setting-input"
      type="digit"
      value="{{thresholdInput}}"
      bindinput="onThresholdInput"
      placeholder="请输入报警阈值"
    />

    <view class="button-row">
      <button class="primary-button" bindtap="onSaveThresholdTap">保存阈值</button>
      <button class="secondary-button" bindtap="onResetThresholdTap">恢复默认</button>
    </view>
  </view>

  <view class="panel">
    <view class="section-title">设备名称</view>
    <view class="section-subtitle">你可以给设备起一个更容易识别的名字，首页和设备页会同步显示。</view>

    <view class="device-summary">
      <view>
        <view class="device-name">{{deviceDisplayName}}</view>
        <view class="device-status">当前设备状态</view>
      </view>
      <view class="status-pill {{onlineStatus.tone}}">{{onlineStatus.text}}</view>
    </view>

    <view class="input-label">设备名称</view>
    <input
      class="setting-input"
      value="{{nicknameInput}}"
      bindinput="onNicknameInput"
      maxlength="32"
      placeholder="例如：车间 1 号设备"
    />

    <button class="primary-button single-action" bindtap="onSaveNicknameTap" loading="{{savingNickname}}">
      {{savingNickname ? "正在保存..." : "保存设备名称"}}
    </button>
  </view>

  <view class="panel">
    <view class="section-title">实用工具</view>
    <view class="section-subtitle">查看当前城市天气，方便巡检和现场判断。</view>

    <view class="setting-row ble-entry" bindtap="onWeatherTap">
      <view class="setting-copy">
        <view class="setting-title">天气实况</view>
        <view class="setting-desc">查看当前城市天气，用于现场巡检或环境参考。</view>
      </view>
      <view class="setting-value">进入</view>
    </view>
  </view>

  <view class="panel version-card" bindtap="onVersionTap">
    <view class="section-title">关于</view>
    <view class="section-subtitle">当前版本 {{versionText}}</view>
    <view class="version-hint">如需排查问题，可联系开发者或售后支持。</view>
  </view>

  <view class="error-card" wx:if="{{errorMessage}}">
    <view class="error-title">设置操作未完成</view>
    <view class="error-text">{{errorMessage}}</view>
  </view>
</view>
