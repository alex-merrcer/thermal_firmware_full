.weather-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.input-label {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #7c7066;
}

.setting-input {
  margin-top: 14rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: rgba(247, 243, 236, 0.92);
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #241b15;
}

.button-row {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.weather-hero {
  background:
    radial-gradient(circle at top left, rgba(255, 210, 156, 0.58), transparent 36%),
    linear-gradient(145deg, rgba(33, 22, 15, 0.96), rgba(111, 52, 29, 0.92));
  color: #fff8ef;
}

.weather-city {
  font-size: 34rpx;
  font-weight: 700;
}

.weather-text {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(255, 241, 224, 0.9);
}

.weather-temp {
  margin-top: 18rpx;
  font-size: 72rpx;
  line-height: 1;
  font-weight: 800;
}

.weather-source {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: rgba(255, 241, 224, 0.72);
}
