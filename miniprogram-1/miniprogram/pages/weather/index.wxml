<view class="page-shell weather-page">
  <view class="panel">
    <view class="section-title">天气实况</view>
    <view class="section-subtitle">手动输入城市后可直接查询；未保存时，默认显示佛山。</view>

    <view class="input-label">城市名称</view>
    <input
      class="setting-input"
      value="{{cityInput}}"
      bindinput="onCityInput"
      maxlength="32"
      placeholder="请输入城市名称"
    />

    <view class="button-row">
      <button class="primary-button weather-action-button" bindtap="onSaveCityTap">查询</button>
      <button class="secondary-button weather-action-button weather-secondary-action" bindtap="onUseDefaultCityTap">默认城市</button>
    </view>
  </view>

  <view class="panel weather-hero">
    <view class="weather-location">{{weather.locationText}}</view>
    <view class="weather-city">{{weather.cityName}}</view>
    <view class="weather-row">
      <view class="weather-text">{{weather.text}}</view>
      <view class="weather-air">{{weather.airText}}</view>
    </view>
    <view class="weather-temp">{{weather.temperatureText}}</view>
    <view class="weather-range">最高 / 最低 {{weather.rangeText}}</view>
    <view class="weather-source">更新时间：{{weather.reportText}}</view>
  </view>

  <view class="summary-grid">
    <view class="panel summary-card" wx:for="{{weather.summaryItems}}" wx:key="key">
      <view class="summary-label">{{item.label}}</view>
      <view class="summary-value">{{item.value}}</view>
    </view>
  </view>

  <view class="panel" wx:if="{{weather.forecastItems.length}}">
    <view class="section-title">未来 3 天</view>
    <view class="forecast-list">
      <view class="forecast-item" wx:for="{{weather.forecastItems}}" wx:key="key">
        <view class="forecast-main">
          <view class="forecast-week">{{item.week}}</view>
          <view class="forecast-date">{{item.date}}</view>
        </view>
        <view class="forecast-copy">
          <view class="forecast-weather">{{item.weatherText}}</view>
          <view class="forecast-extra">{{item.extraText}}</view>
        </view>
        <view class="forecast-temp">{{item.tempText}}</view>
      </view>
    </view>
  </view>

  <view class="panel" wx:if="{{weather.hourlyItems.length}}">
    <view class="section-title">逐小时预报</view>
    <scroll-view class="hourly-scroll" scroll-x enable-flex>
      <view class="hourly-list">
        <view class="hourly-item" wx:for="{{weather.hourlyItems}}" wx:key="key">
          <view class="hourly-time">{{item.timeText}}</view>
          <view class="hourly-weather">{{item.weatherText}}</view>
          <view class="hourly-temp">{{item.tempText}}</view>
          <view class="hourly-rain">{{item.rainText}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="panel" wx:if="{{weather.lifeItems.length}}">
    <view class="section-title">生活建议</view>
    <view class="life-list">
      <view class="life-item" wx:for="{{weather.lifeItems}}" wx:key="key">
        <view class="life-head">
          <view class="life-title">{{item.title}}</view>
          <view class="life-brief">{{item.brief}}</view>
        </view>
        <view class="life-advice">{{item.advice}}</view>
      </view>
    </view>
  </view>

  <button class="primary-button" bindtap="onRefreshTap" loading="{{loading}}">
    {{loading ? "正在获取..." : "刷新天气"}}
  </button>

  <view class="error-card" wx:if="{{errorMessage}}">
    <view class="error-title">天气获取未完成</view>
    <view class="error-text">{{errorMessage}}</view>
  </view>
</view>
