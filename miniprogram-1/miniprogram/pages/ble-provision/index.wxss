.ble-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.status-row {
  margin-top: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.mini-actions {
  flex-shrink: 0;
}

.compact-button {
  min-width: 156rpx;
  min-height: 64rpx;
  font-size: 24rpx;
  padding: 0 18rpx;
}

.scan-meta-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.scan-meta-item {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(247, 243, 236, 0.92);
  font-size: 22rpx;
  color: #6a5648;
}

.device-item {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: center;
  padding: 22rpx 0;
  border-top: 1rpx solid rgba(36, 27, 21, 0.08);
}

.device-item:first-of-type {
  margin-top: 12rpx;
}

.setting-copy {
  flex: 1;
}

.device-topline {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
}

.setting-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #241b15;
}

.device-badge {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.device-badge.candidate {
  background: rgba(80, 106, 160, 0.14);
  color: #506aa0;
}

.device-badge.plain {
  background: rgba(124, 115, 105, 0.12);
  color: #7c7369;
}

.setting-desc {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: #7d6f62;
}

.device-meta {
  margin-top: 6rpx;
  font-size: 21rpx;
  color: #9b8c80;
}

.setting-value {
  flex-shrink: 0;
  font-size: 25rpx;
  color: #5c4434;
}

.input-label {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #7c7066;
}

.setting-input {
  margin-top: 14rpx;
  height: 80rpx;
  border-radius: 22rpx;
  background: rgba(247, 243, 236, 0.92);
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #241b15;
}

.button-grid {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.log-item {
  padding: 18rpx 0;
  border-top: 1rpx solid rgba(36, 27, 21, 0.08);
  font-size: 23rpx;
  line-height: 1.6;
  color: #624736;
  word-break: break-all;
}

.log-item:first-of-type {
  margin-top: 12rpx;
}
